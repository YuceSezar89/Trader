# TRader Panel Environment Variables
# =====================================
# Bu dosyayı .env olarak kopyalayın ve değerleri düzenleyin

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=trader_panel
DB_USER=postgres
DB_PASSWORD=your_password_here

# Redis
REDIS_URL=redis://localhost:6379/0

# Binance API (opsiyonel - sadece gerçek trading için)
BINANCE_API_KEY=
BINANCE_API_SECRET=
